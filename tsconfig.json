
{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",

    "strict": false,
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,

    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"]
}
